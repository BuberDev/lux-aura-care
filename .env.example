# Optional: enables a frequently refreshed USD/PLN rate from CurrencyAPI.
# Without this key the app uses the latest official NBP reference rate.
CURRENCY_API_KEY=

# Analytics pixels — each script loads only when its ID is set.
# GA4: view_item + begin_checkout events fire on shop product pages.
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
# Meta (Facebook/Instagram) pixel: PageView, ViewContent, InitiateCheckout.
NEXT_PUBLIC_META_PIXEL_ID=
# TikTok pixel: page, ViewContent, InitiateCheckout.
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
